# ── Application ────────────────────────────────────────────
APP_NAME="AI Voice Assistant API"
APP_VERSION="1.0.0"
DEBUG=False

# ── Server ─────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── CORS ───────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000"]

# ── Database ───────────────────────────────────────────────
DATABASE_URL=sqlite:///./dev.db

# ── Security ───────────────────────────────────────────────
SECRET_KEY=change-this-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30