# ── Application ────────────────────────────────────────────
APP_NAME="AI Voice Assistant API"
APP_VERSION="1.0.0"
DEBUG=False

# ── Server ─────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── CORS ───────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000"]

# ── Database ───────────────────────────────────────────────
DATABASE_URL=sqlite:///./dev.db

# ── Security ───────────────────────────────────────────────
SECRET_KEY=change-this-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── OpenAI (REQUIRED) ──────────────────────────────────────
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...your-key-here...

# ── STT — Whisper ──────────────────────────────────────────
STT_MODEL=whisper-1
# Leave blank for auto language detection, or set "hi" to force Hindi
STT_LANGUAGE=

# ── LLM ────────────────────────────────────────────────────
# gpt-4o-mini  (cheap + fast)  |  gpt-4o  (smarter, pricier)
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=500

# ── TTS — OpenAI Speech ────────────────────────────────────
TTS_MODEL=tts-1
# Voices: alloy | echo | fable | onyx | nova | shimmer
TTS_VOICE=nova
# Formats: mp3 | opus | aac | flac
TTS_FORMAT=mp3

# ── Conversation Memory ────────────────────────────────────
MEMORY_MAX_MESSAGES=20
MEMORY_SESSION_TTL_MINUTES=60

# ── Audio Upload Limits ────────────────────────────────────
AUDIO_MAX_SIZE_MB=25
